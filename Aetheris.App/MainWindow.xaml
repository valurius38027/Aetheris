<Window x:Class="Aetheris.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Aetheris.App"
        mc:Ignorable="d"
        Title="Aetheris - Extreme Sovereignty" Height="700" Width="1100" 
        Background="#0F0F0F" WindowStyle="SingleBorderWindow" WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="#00FF41" BorderThickness="0,0,0,0" x:Name="border">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A1A1A"/>
                                <Setter Property="Foreground" Value="#00FF41"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Active">
                                <Setter Property="Foreground" Value="#00FF41"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="3,0,0,0"/>
                                <Setter Property="Background" Value="#151515"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainContentArea">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation -->
        <Border Grid.Column="0" Background="#121212" BorderBrush="#252525" BorderThickness="0,0,1,0" Padding="10,0,0,0">
            <DockPanel>
                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="20,40,20,40">
                    <TextBlock Text="AETHERIS" FontSize="26" FontWeight="Bold" Foreground="#00FF41" FontFamily="Consolas"/>
                    <TextBlock Text="v0.1.0-alpha" Foreground="#444444" FontSize="11" Margin="2,0,0,0"/>
                </StackPanel>

                <!-- Navigation Buttons -->
                <StackPanel DockPanel.Dock="Top">
                    <Button Content="Overview" Style="{StaticResource SidebarButton}" Tag="Active" Click="Nav_Click"/>
                    <Button Content="Shielded Wallet" Style="{StaticResource SidebarButton}" Click="Nav_Click"/>
                    <Button Content="Switch Vault" Style="{StaticResource SidebarButton}" Click="Nav_Click"/>
                    <Button Content="Node Status" Style="{StaticResource SidebarButton}" Click="Nav_Click"/>
                    <Button Content="Mixnet Privacy" Style="{StaticResource SidebarButton}" Click="Nav_Click"/>
                    <Button Content="Settings" Style="{StaticResource SidebarButton}" Click="Nav_Click"/>
                </StackPanel>

                <!-- Bottom Status -->
                <StackPanel DockPanel.Dock="Bottom" Margin="20" VerticalAlignment="Bottom">
                    <Separator Background="#252525" Margin="0,0,0,15"/>
                    <TextBlock Text="NETWORK STATUS" Foreground="#444444" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#00FF41" Margin="0,0,8,0"/>
                        <TextBlock x:Name="BottomStatusText" Text="Connected" Foreground="#AAAAAA" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
                
                <Grid/> <!-- Spacer -->
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/> <!-- Top Menu Bar -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Overlay for No Wallet State -->
            <Grid x:Name="NoWalletOverlay" Grid.RowSpan="2" Panel.ZIndex="999" Visibility="Visible">
                <Rectangle Fill="#151515" Opacity="1.0"/>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Background="#1A1A1A" CornerRadius="15" Padding="40" BorderBrush="#333333" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="⚠" FontSize="64" Foreground="#00FF41" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                            <TextBlock Text="AETHERIS VAULT LOCKED" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="No encrypted wallet container was found in the kernel root." Foreground="#888" HorizontalAlignment="Center" Margin="0,15,0,40" FontSize="14"/>
                            <Button Content="INITIALIZE SECURE VAULT" Width="280" Height="50" Background="#00FF41" Foreground="Black" FontWeight="Bold" FontSize="14" BorderThickness="0" Click="BtnInitializeFromOverlay_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Top Menu Bar -->
            <Border Grid.Row="0" Background="#121212" BorderBrush="#252525" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="DASHBOARD" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Separator Width="1" Height="20" Margin="15,0" Background="#333333"/>
                        <TextBlock x:Name="SyncStatusText" Text="Synchronized: 100%" Foreground="#888888" VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BtnNewTransaction" Content="New Transaction" Background="#00FF41" Foreground="Black" Padding="15,5" FontWeight="Bold" BorderThickness="0" Click="BtnNewTransaction_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Panels -->
            <Grid Grid.Row="1" Margin="30">
                <!-- Transaction Modal Overlay -->
                <Grid x:Name="TransactionModal" Visibility="Collapsed" Panel.ZIndex="100">
                    <Border Background="#CC000000"/>
                    <Border Background="#1A1A1A" CornerRadius="12" Width="450" Height="400" VerticalAlignment="Center" HorizontalAlignment="Center" BorderBrush="#333333" BorderThickness="1">
                        <StackPanel Margin="30">
                            <TextBlock Text="NEW SHIELDED TRANSFER" Foreground="#00FF41" FontSize="18" FontWeight="Bold" Margin="0,0,0,25"/>
                            
                            <TextBlock Text="RECIPIENT ADDRESS" Foreground="#888888" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBox x:Name="TxtRecipient" Background="#0A0A0A" Foreground="White" BorderBrush="#333333" Padding="10" Margin="0,0,0,20" CaretBrush="#00FF41"/>
                            
                            <TextBlock Text="AMOUNT (AET)" Foreground="#888888" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBox x:Name="TxtAmount" Background="#0A0A0A" Foreground="White" BorderBrush="#333333" Padding="10" Margin="0,0,0,30" CaretBrush="#00FF41"/>
                            
                            <Grid x:Name="TxActionGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="CANCEL" Background="Transparent" Foreground="#888888" Margin="0,0,10,0" Click="BtnCancelTx_Click" BorderBrush="#333333"/>
                                <Button x:Name="BtnConfirmTx" Grid.Column="1" Content="CONFIRM &amp; SIGN" Background="#00FF41" Foreground="Black" FontWeight="Bold" Click="BtnConfirmTx_Click" BorderThickness="0"/>
                            </Grid>

                            <StackPanel x:Name="TxStatusPanel" Visibility="Collapsed" Margin="0,10,0,0">
                                <ProgressBar x:Name="TxProgressBar" Height="4" IsIndeterminate="True" Background="#333333" Foreground="#00FF41" BorderThickness="0"/>
                                <TextBlock x:Name="TxStatusText" Text="Generating ZK-SNARK Proof..." Foreground="#00FF41" FontSize="11" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Overview Panel -->
                <Grid x:Name="OverviewPanel" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#1A1A1A" CornerRadius="8" Margin="0,0,10,0" Padding="20">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="TOTAL BALANCE" Foreground="#666666" FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
                                <TextBlock x:Name="BalanceText" Text="0.00 AET" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,5,0,0" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Grid.Column="1" Background="#1A1A1A" CornerRadius="8" Margin="5,0,5,0" Padding="20">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="ACTIVE PEERS" Foreground="#666666" FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
                                <TextBlock x:Name="PeersText" Text="0" Foreground="#00FF41" FontSize="22" FontWeight="Bold" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Grid.Column="2" Background="#1A1A1A" CornerRadius="8" Margin="10,0,0,0" Padding="20">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="PRIVACY SCORE" Foreground="#666666" FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
                                <TextBlock x:Name="PrivacyScoreText" Text="0%" Foreground="#00FF41" FontSize="22" FontWeight="Bold" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Recent Transactions -->
                        <Border Grid.Column="0" Background="#151515" CornerRadius="8" Padding="20" Margin="0,0,15,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="RECENT ANONYMOUS ACTIVITY" Foreground="#444444" FontSize="12" FontWeight="Bold" Margin="0,0,0,20"/>
                                <ListBox x:Name="TransactionList" Background="Transparent" BorderThickness="0">
                                    <!-- Dynamic transactions will be added here -->
                                </ListBox>
                            </DockPanel>
                        </Border>

                        <!-- Node Console -->
                        <Border Grid.Column="1" Background="#0A0A0A" CornerRadius="8" Padding="15">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="SYSTEM CONSOLE" Foreground="#00FF41" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                <ScrollViewer x:Name="LogScrollViewer">
                                    <TextBlock x:Name="LogText" Text="[INIT] Kernel started...&#x0a;[P2P] Searching for nodes...&#x0a;[MIX] Cover traffic engaged." 
                                               Foreground="#00FF41" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Shielded Wallet Panel -->
                <Grid x:Name="WalletPanel" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="MY SHIELDED ADDRESS" Foreground="#888888" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>
                        <Border Background="#1A1A1A" CornerRadius="8" Padding="20" BorderBrush="#333333" BorderThickness="1">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="COPY" Background="#333333" Foreground="White" Padding="15,5" BorderThickness="0" Margin="10,0,0,0" Click="BtnCopyAddress_Click"/>
                                <TextBlock x:Name="WalletAddressText" Text="Generating..." Foreground="#00FF41" FontSize="16" FontFamily="Consolas" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                        
                        <Grid Margin="0,30,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Background="#151515" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="SHIELDED ASSETS" Foreground="#444444" FontSize="10" FontWeight="Bold" Margin="0,0,0,15"/>
                                    <Grid Margin="0,0,0,10">
                                        <TextBlock Text="AET (Native)" Foreground="White"/>
                                        <TextBlock x:Name="WalletAetBalance" Text="0.00" Foreground="White" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid>
                                        <TextBlock Text="sBTC (Wrapped)" Foreground="#888888"/>
                                        <TextBlock Text="0.00" Foreground="#888888" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Button Content="SEND PRIVATE TRANSACTION" Background="#00FF41" Foreground="Black" FontWeight="Bold" Padding="0,10" BorderThickness="0" Margin="0,20,0,0" Click="BtnSendTransaction_Click"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="#151515" CornerRadius="8" Padding="20" Margin="10,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="ANONYMITY SET SIZE" Foreground="#444444" FontSize="10" FontWeight="Bold" Margin="0,0,0,15"/>
                                    <TextBlock x:Name="AnonymitySetText" Text="Calculating..." Foreground="#00FF41" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text="Global privacy pool contributors" Foreground="#888888" FontSize="10" Margin="0,5,0,0"/>
                                    <Separator Background="#222222" Margin="0,15,0,15"/>
                                    <TextBlock Text="ZK-PROOF SYSTEM" Foreground="#444444" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                    <TextBlock Text="Halo2 (KZG-BN254)" Foreground="White" FontSize="12"/>
                                    <TextBlock Text="Status: Production Ready" Foreground="#00FF41" FontSize="10" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- Settings Panel -->
                <Grid x:Name="SettingsPanel" Visibility="Collapsed">
                    <Border Background="#151515" CornerRadius="8" Padding="30">
                        <StackPanel>
                            <TextBlock Text="SYSTEM SETTINGS" Foreground="#00FF41" FontSize="14" FontWeight="Bold" Margin="0,0,0,30"/>
                            
                            <TextBlock Text="SECURITY" Foreground="#444444" FontSize="10" FontWeight="Bold" Margin="0,0,0,15"/>
                            <DockPanel Margin="0,0,0,25">
                                <StackPanel>
                                    <TextBlock Text="Backup Vault" Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Export your encrypted mnemonic phrase" Foreground="#888888" FontSize="11" Margin="0,5,0,0"/>
                                </StackPanel>
                                <Button Content="EXPORT" Background="#333333" Foreground="White" Padding="20,8" BorderThickness="0" HorizontalAlignment="Right" Click="BtnRevealMnemonic_Click"/>
                            </DockPanel>

                            <TextBlock Text="NETWORK" Foreground="#444444" FontSize="10" FontWeight="Bold" Margin="0,0,0,15"/>
                            <DockPanel Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="Mixnet Routing" Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Route all traffic through the Aetheris Mixnet" Foreground="#888888" FontSize="11" Margin="0,5,0,0"/>
                                </StackPanel>
                                <CheckBox IsChecked="True" HorizontalAlignment="Right"/>
                            </DockPanel>
                            
                            <DockPanel Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="P2P Discovery" Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Enable mDNS and DHT for node discovery" Foreground="#888888" FontSize="11" Margin="0,5,0,0"/>
                                </StackPanel>
                                <CheckBox IsChecked="True" HorizontalAlignment="Right"/>
                            </DockPanel>

                            <Separator Background="#222222" Margin="0,10,0,30"/>
                            <Button Content="WIPE LOCAL DATA" Background="#FF4141" Foreground="White" FontWeight="Bold" Padding="0,12" BorderThickness="0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Node Status Panel -->
                <Grid x:Name="NodePanel" Visibility="Collapsed">
                    <Border Background="#151515" CornerRadius="8" Padding="30">
                        <StackPanel>
                            <TextBlock Text="NODE OPERATIONAL PARAMETERS" Foreground="#00FF41" FontSize="14" FontWeight="Bold" Margin="0,0,0,30"/>
                            
                            <Grid Margin="0,0,0,15">
                                <TextBlock Text="Network Version" Foreground="#888888"/>
                                <TextBlock x:Name="VersionText" Text="v0.1.0-alpha" Foreground="White" HorizontalAlignment="Right"/>
                            </Grid>
                            <Separator Background="#222222" Margin="0,0,0,15"/>
                            
                            <Grid Margin="0,0,0,15">
                                <TextBlock Text="P2P Port" Foreground="#888888"/>
                                <TextBlock Text="10001 (TCP/UDP)" Foreground="White" HorizontalAlignment="Right"/>
                            </Grid>
                            <Separator Background="#222222" Margin="0,0,0,15"/>

                            <Grid Margin="0,0,0,15">
                                <TextBlock Text="Block Height" Foreground="#888888"/>
                                <TextBlock x:Name="HeightText" Text="0" Foreground="White" HorizontalAlignment="Right"/>
                            </Grid>
                            <Separator Background="#222222" Margin="0,0,0,15"/>

                            <Grid>
                                <TextBlock Text="Network Status" Foreground="#888888"/>
                                <TextBlock Text="Standalone / Bootstrap" Foreground="#00FF41" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Mixnet Privacy Panel -->
                <Grid x:Name="MixnetPanel" Visibility="Collapsed">
                    <Border Background="#151515" CornerRadius="8" Padding="30">
                        <StackPanel>
                            <TextBlock Text="AETHERIS MIXNET ROUTING" Foreground="#00FF41" FontSize="14" FontWeight="Bold" Margin="0,0,0,30"/>
                            
                            <Border Background="#0A0A0A" Padding="20" CornerRadius="8" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="Active Hops: 3 (Standard)" Foreground="#888888" FontSize="12"/>
                                    <TextBlock Text="Circuit: [Self] -> [AetNode-12] -> [AetNode-05] -> [Destination]" Foreground="#00FF41" FontSize="11" FontFamily="Consolas" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="ANONYMITY TRAFFIC" Foreground="#444444" FontSize="10" FontWeight="Bold" Margin="0,0,0,15"/>
                            <ProgressBar Height="10" Value="100" Foreground="#00FF41" Background="#333333" BorderThickness="0" Margin="0,0,0,20"/>
                            
                            <TextBlock Text="All transactions are automatically routed through the Sphinx-mixnet to prevent IP-to-Address correlation." Foreground="#888888" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Vault Switcher Panel -->
                <Grid x:Name="VaultPanel" Visibility="Collapsed">
                    <Border Background="#151515" CornerRadius="8" Padding="30">
                        <StackPanel>
                            <TextBlock Text="VAULT MANAGEMENT" Foreground="#00FF41" FontSize="14" FontWeight="Bold" Margin="0,0,0,30"/>
                            <TextBlock Text="Active Vault Path:" Foreground="#888888" FontSize="12" Margin="0,0,0,5"/>
                            <TextBlock x:Name="ActiveVaultPathText" Text="Loading..." Foreground="White" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,25"/>
                            
                            <TextBlock Text="SWITCH OR CREATE VAULT" Foreground="#444444" FontSize="10" FontWeight="Bold" Margin="0,0,0,15"/>
                            <TextBlock Text="Enter a folder name for the new/existing vault:" Foreground="#888888" FontSize="11" Margin="0,0,0,10"/>
                            <TextBox x:Name="TxtVaultName" Background="#1A1A1A" Foreground="White" BorderBrush="#333333" Padding="10" Margin="0,0,0,20" Text="my_new_vault"/>
                            
                            <Button Content="SWITCH TO THIS VAULT" Background="#00FF41" Foreground="Black" FontWeight="Bold" Padding="0,12" BorderThickness="0" Click="BtnSwitchVault_Click"/>
                            <TextBlock Text="Note: Switching vaults will re-initialize the kernel database instance." Foreground="#666666" FontSize="10" Margin="0,10,0,0" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
        <!-- Notifications Layer -->
        <ItemsControl x:Name="NotificationContainer" Grid.RowSpan="2" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,20,20,0" Panel.ZIndex="1000">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" CornerRadius="4" Margin="0,0,0,10" Width="300" Padding="15">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.5"/>
                        </Border.Effect>
                        <DockPanel>
                            <Ellipse DockPanel.Dock="Left" Width="8" Height="8" Fill="{Binding Color}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                <TextBlock Text="{Binding Message}" Foreground="#888888" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>
